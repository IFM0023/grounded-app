{
  "buildCommand": "npm run build",
  "outputDirectory": "www",
  "rewrites": [
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/privacy/", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/terms/", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/contact/", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": { "memory": 1024, "maxDuration": 30 },
    "api/chapter-explain-structured.js": { "memory": 1024, "maxDuration": 60 },
    "api/chapter-explain.js": { "memory": 1024, "maxDuration": 60 },
    "api/verse-explain-structured.js": { "memory": 1024, "maxDuration": 45 },
    "api/book-overview.js": { "memory": 1024, "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
